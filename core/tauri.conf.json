{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Caret",
  "version": "0.1.0",
  "identifier": "com.voxire.caret",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Caret",
        "width": 900,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": true,
        "titleBarStyle": "overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/voxire/caret/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
