{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Codrift",
  "version": "0.0.48",
  "identifier": "com.stackxio.codrift",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Codrift",
        "width": 900,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#1e1e1e",
        "windowEffects": {
          "effects": [
            "sidebar"
          ],
          "state": "followsWindowActiveState"
        },
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/stackxio/codrift/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDQUFGQzZBRTg3NkJFRDUKUldUVnZuYm9hdnlxckNqbmRyMzl3VExQQ1dMcHljTURwbE1KUUJ4VlArS0hRaUxXcmd5VEwwZXQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
