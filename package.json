{
  "name": "blink",
  "private": true,
  "version": "0.0.14",
  "packageManager": "bun@1.3.10",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && bun run bundle:bridge",
    "bundle:bridge": "bun build packages/blink-code/ide-bridge.ts --outfile core/bridge/ide-bridge.js --target bun",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format:js": "prettier --write .",
    "format:js:check": "prettier --check .",
    "format:rust": "cargo fmt --manifest-path core/Cargo.toml --all",
    "format:rust:check": "cargo fmt --manifest-path core/Cargo.toml --all --check",
    "format": "bun run format:js && bun run format:rust",
    "format:check": "bun run format:js:check && bun run format:rust:check",
    "hooks:install": "git config core.hooksPath .githooks",
    "preview": "vite preview",
    "tauri": "TAURI_DIR=core tauri",
    "icon": "node scripts/icon-prep.mjs && bun run tauri icon core/app-icon.png && node scripts/prune-mobile-icons.mjs",
    "app": "bash scripts/start-dev-app.sh",
    "app:build": "bun run tauri build",
    "db:reset": "rm -f ~/.blink/blink.db && echo 'Database reset. It will be recreated on next app launch.'"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-angular": "^0.1.4",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-less": "^6.0.2",
    "@codemirror/lang-liquid": "^6.3.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-wast": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@replit/codemirror-minimap": "^0.5.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.577.0",
    "material-icon-theme": "^5.33.1",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "trustedDependencies": [
    "esbuild",
    "sharp"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-toml": "^2.0.6",
    "sass": "^1.98.0",
    "sharp": "^0.33.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
